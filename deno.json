{
  "tasks": {
    "build": "deno run --allow-write build.ts",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "test": "deno test",
    "check": "deno check src/"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false,
    "semiColons": true,
    "include": ["src/", "build.ts"]
  },
  "lint": {
    "include": ["src/", "build.ts"],
    "rules": {
      "tags": ["recommended"]
    }
  },
  "test": {
    "include": ["src/"]
  }
}
