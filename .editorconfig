root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown allows trailing spaces for hard line breaks.
[*.md]
trim_trailing_whitespace = false

# Generated artifacts — preserve exact byte format from build.ts.
[colors/*.itermcolors]
indent_style = tab
trim_trailing_whitespace = true
